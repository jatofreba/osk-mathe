  "task_html": "<a href=\"https://www.youtube.com/watch?v=-w9fvaoG4NE&list=PLCwTOdPGQsAyGFOl88eq6XEUYeof5JAh-&index=4\" target=\"_blank\" class=\"video-link-card\" style=\"margin-bottom:16px;\">\n  <div class=\"video-link-icon\">▶</div>\n  <div class=\"video-link-text\">\n    <div class=\"video-link-title\">Raummaße umrechnen</div>\n    <div class=\"video-link-sub\">YouTube: Einfach erklärt · Rechnen mit Größen</div>\n  </div>\n  <div class=\"video-link-arrow\">↗</div>\n</a>\n<p style=\"font-size:14px;margin:0 0 14px 0;\"><strong>Ergänze die fehlenden Werte in der Tabelle.</strong></p>\n\n<div class=\"task-block task-orange\">\n  <div class=\"task-block-label\">Volumenmaße</div>\n  <div class=\"tbl-wrap\"><table>\n    <thead><tr><th>mm³</th><th>cm³</th><th>dm³ (= l)</th><th>m³</th></tr></thead>\n    <tbody>\n      <tr>\n        <td><input class=\"cell-input\" data-ans=\"330000\" placeholder=\"?\"></td>\n        <td class=\"given\">330 cm³</td>\n        <td><input class=\"cell-input\" data-ans=\"0.33\" placeholder=\"?\"></td>\n        <td><input class=\"cell-input\" data-ans=\"0.00033\" placeholder=\"?\"></td>\n      </tr>\n      <tr>\n        <td class=\"given\">8 000 000 mm³</td>\n        <td><input class=\"cell-input\" data-ans=\"8000\" placeholder=\"?\"></td>\n        <td><input class=\"cell-input\" data-ans=\"8\" placeholder=\"?\"></td>\n        <td><input class=\"cell-input\" data-ans=\"0.008\" placeholder=\"?\"></td>\n      </tr>\n    </tbody>\n  </table></div>\n</div>\n\n<div class=\"check-bar\">\n  <button class=\"btn-check\" onclick=\"checkEinheitenVolumen()\">✓ Überprüfen</button>\n  <button class=\"btn-reset\" onclick=\"resetEinheitenVolumen()\">↺ Zurücksetzen</button>\n  <span class=\"check-result\" id=\"check-result-einheiten-volumen\"></span>\n</div>\n<div class=\"task-block task-orange\" style=\"margin-top:14px;\">\n  <div class=\"task-block-label\">✏️ Erkläre</div>\n  <p style=\"font-size:14px;line-height:1.7;margin-bottom:8px;\">Erkläre: Warum hat cm³ → m³ den Faktor 1/1,000.000 (also ÷1,000.000)? Und warum gilt: 1 dm³ = 1 Liter?</p>\n  <textarea style=\"width:100%;min-height:70px;padding:8px 10px;border:1.5px solid #fed7aa;border-radius:8px;font-size:13px;font-family:inherit;resize:vertical;\" placeholder=\"Deine Erklärung...\"></textarea>\n  <p style=\"font-size:12px;color:var(--ink2);margin-top:6px;\">💡 Denke räumlich: Ein Würfel mit 1 m Kantenlänge hat 100 cm × 100 cm × 100 cm = ? cm³</p>\n</div>",
  "sol_html": "<div class=\"h2-example\" style=\"margin:0;\"><div class=\"h2-example-title\">Lösung</div><div class=\"h2-example-calc\">\n<div class=\"tbl-wrap\"><table>\n  <thead><tr><th>mm³</th><th>cm³</th><th>dm³ (= l)</th><th>m³</th></tr></thead>\n  <tbody>\n    <tr><td>330 000</td><td class=\"given\">330</td><td>0,33</td><td>0,00033</td></tr>\n    <tr><td class=\"given\">8 000 000</td><td>8 000</td><td>8</td><td>0,008</td></tr>\n  </tbody>\n</table></div>\n<p style=\"font-size:13px;margin-top:10px;\">Bei Volumen: jede Stufe = ÷1 000 &nbsp;(weil Länge³ → Faktor wird kubiert)</p>\n</div></div>"
